---

import ServiceSection from "../components/ServiceSection.astro"
import BaseLayout from "../layouts/BaseLayout.astro"
import Card from "../components/Card.astro"
import SectionHero from "../components/HeroBanners/SectionHero.astro"
import IconCard from "../components/IconCard.astro"
const pageTitle = "Servicios - C2R";
---

<BaseLayout pageTitle={pageTitle}>
    <SectionHero 
        title="Nuestros Servicios" 
        subtitle="Excelencia Operativa" 
        description="Ofrecemos soluciones integrales para fortalecer la gestión de calidad y la seguridad operativa. Optimizamos procesos institucionales bajo normativas nacionales e internacionales, aplicables al sector salud y organizaciones de alto impacto." 
        imgPath="/img/servicios_hero_background.webp"
    />
    <section class="flex flex-col gap-20 my-10">
        <ServiceSection title="1. Asistencia y Asesoría en Sistemas de Gestión de Calidad Hospitalaria">
            <p>
                Acompañamos a las instituciones de salud en el desarrollo, implementación y mejora continua de sistemas de gestión de 
                calidad hospitalaria, asegurando el cumplimiento de normativas y estándares vigentes.
            </p>
        </ServiceSection>
        <ServiceSection title="2. Capacitación y Aplicación de Estándares de la Joint Commission International (JCI) – 8ª Edición">
            <p>
                Brindamos formación y soporte en la interpretación, implementación y evaluación de los estándares JCI, incluyendo:
            </p>
            <section class="flex flex-col mt-7">
                <Card title="Sección II – Estándares centrados en el paciente">
                    <ul class="list-disc ml-5">
                        <li>ACC – Acceso a la atención y continuidad de la misma</li>
                        <li>AOP – Evaluación de pacientes</li>
                        <li>ASC – Anestesia y atención quirúrgica</li>
                        <li>COP – Atención de los pacientes</li>
                        <li>IPSG – Metas internacionales para la seguridad del paciente</li>
                        <li>MMU – Manejo y uso de medicamentos</li>
                        <li>PCC – Derechos del paciente y la familia</li>
                    </ul>
                </Card>
                <Card title="Sección III – Estándares de gestión centrados en la organización">
                    <ul class="list-disc ml-5">
                        <li>FMS – Administración y seguridad de las instalaciones</li>
                        <li>GLD – Órgano de Gobierno, liderazgo y dirección</li>
                        <li>HCT – Tecnología de la salud</li>
                        <li>MOI – Gestión de la información</li>
                        <li>PCI – Prevención y control de infecciones</li>
                        <li>QPS – Mejora de la calidad y la seguridad de los pacientes</li>
                        <li>SQE – Calificaciones y educación del personal</li>
                    </ul>
                </Card>
                <Card title="Sección IV – Impacto en la Salud Mundial">
                    <ul class="list-disc ml-5">
                        <li>GHI – Impacto en la salud mundial</li>
                    </ul>
                </Card>
                <Card title="Sección V – Hospital Docente">
                    <ul class="list-disc ml-5">
                        <li>HR – Programas de investigación con sujetos humanos</li>
                        <li>MPE – Educación de profesionales médicos</li>
                    </ul>
                </Card>
            </section>
        </ServiceSection>
        <ServiceSection title="3. Implementación de Programas de Calidad y Seguridad del Paciente">
            <Card title="3.1 Gestión Documental">
                <p>Creación, control y mejora de la documentación institucional.</p>
            </Card>
            <Card title="3.2 Vigilancia Activa">
                <ul class="list-disc ml-5">
                    <li>Auditorías</li>
                    <li>Tracers</li>
                    <li>Paciente misterioso</li>
                    <li>Indicadores</li>
                    <li>Gestión de riesgo</li>
                </ul>
            </Card>
            <Card title="3.3 Vigilancia Pasiva">
                <ul class="list-disc ml-5">
                    <li>Reporte de incidentes, eventos adversos y centinela</li>
                    <li>Gestión de quejas de pacientes</li>
                    <li>Trazabilidad de dispositivos médicos implantables</li>
                    <li>Farmacovigilancia</li>
                    <li>Trazabilidad de insumos médicos</li>
                    <li>Reporte de fallas de equipos médicos</li>
                </ul>
            </Card>
        </ServiceSection>
        <ServiceSection title="4. Programas de Reconocimiento y Premiaciones">
            <p>Fomentamos la cultura de la calidad mediante reconocimientos a la excelencia:</p>
            <section class="mt-5 flex flex-wrap justify-center gap-5 [&>div]:w-[200px] lg:[&>div]:w-[250px]">
                <IconCard name="Premio “Gestión cálida de la calidad”" urlImg="/img/PGCC.png">
                    <p slot="short-content" class="text-xs mt-1">Dirigido a líderes organizacionales.</p>
                </IconCard>
                <IconCard name="Premio “Referente de calidad en seguridad del paciente”" urlImg="/img/PRCS.png">
                    <p slot="short-content" class="text-xs mt-1">Para equipos operativos destacados.</p>
                </IconCard>
                <IconCard name="Premio “La mejora continua”" urlImg="/img/PLMC.png">
                    <p slot="short-content" class="text-xs mt-1">Reconocimiento a equipos de gestión de calidad y seguridad del paciente.</p>
                </IconCard>
            </section>
        </ServiceSection>
        <ServiceSection title="5. Mediciones y Rankings">
            <p>Evaluamos el desempeño institucional con metodologías objetivas y comparativas para impulsar la mejora continua.</p>
        </ServiceSection>
        <ServiceSection title="6. Investigación en Gestión de Calidad y Seguridad del Paciente">
            <p>Realizamos estudios y proyectos de investigación aplicada para generar evidencia y soluciones innovadoras en el ámbito hospitalario.</p>
        </ServiceSection>
    </section>
    <script>
        import '../scripts/card_description.js';	
    </script>
</BaseLayout>