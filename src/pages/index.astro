---
import Header from "../components/Header.astro";
import Service from "../components/Service.astro";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CYTEC2R</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/e4a8bbd630.js" crossorigin="anonymous"></script>
</head>
<body>
    <Header />

	<section class="services">
		<div class="mt-10 mb-10">
			<h1 class="text-6xl text-center text-PrussianBlue font-bold">Nuestros Servicios</h1>
			<h2 class="text-2xl text-center">Soluciones especializadas para tu organización</h2>
		</div>
		<div class="flex justify-center gap-5 flex-wrap">
			<Service name="Seguridad del Paciente" icon="fa-solid fa-shield"/>
			<Service name="Gestión de la Calidad" icon="fa-solid fa-star"/>
			<Service name="Docencia" icon="fa-solid fa-chalkboard-user"/>
			<Service name="Tecnología de Información y Comunicaciones" icon="fa-solid fa-globe"/>
			<Service name="Consultorías" icon="fa-solid fa-circle-info"/>
		</div>
	</section>
	
</body>
</html>
