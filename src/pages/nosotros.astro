---
import SectionHero from "../components/HeroBanners/SectionHero.astro";
import Persona from "../components/Persona.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ValuesColumn from "../components/ValuesColumn.astro";
const pageTitle = "Nosotros - C2R";
---

<BaseLayout pageTitle={pageTitle}>
  <SectionHero
    title="Quiénes Somos"
    subtitle="SOBRE NOSOTROS"
    description="Líderes en consultoría estratégica para la excelencia clínica y la seguridad del paciente."
    imgPath="/img/nosotros_hero_background.png"
  />

  <!-- Philosophy Section (Asymmetric Editorial Style) -->
  <section class="pt-25 pb-10 bg-surface">
    <div class="px-6">
      <div
        class="bg-surface-container-lowest p-8 rounded-xl shadow-sm relative z-20 -mt-16 asymmetric-offset"
      >
        <h2 class="font-headline text-primary text-2xl font-bold mb-4">
          Nuestra Filosofía
        </h2>
        <p class="text-on-surface-variant leading-relaxed text-lg text-justify">
          En Cytec2R, entendemos que la precisión no es solo un objetivo
          técnico, sino un compromiso ético. Nuestra metodología integra el
          rigor científico con una visión humana, transformando la gestión
          hospitalaria en un ecosistema de alta fiabilidad donde cada proceso
          está diseñado para proteger la vida.
        </p>
      </div>
    </div>
  </section>
  <!-- Mission, Vision, Values (Bento Grid Inspired) -->
  <section class="py-12 bg-surface-container-low px-6 flex flex-wrap gap-5 justify-center">
    <div class="flex flex-col gap-5 md:max-w-[45%]">
      <!-- Misión -->
      <div
        class="bg-surface-container-lowest p-8 rounded-xl flex flex-col gap-4"
      >
        <div
          class="w-12 h-12 rounded-lg bg-secondary/10 flex items-center justify-center"
        >
          <span
            class="text-secondary"
            style="font-variation-settings: 'FILL' 1;"
            ><i class="fa-solid fa-bullseye"></i></span
          >
        </div>
        <h3 class="font-headline text-xl font-bold text-primary">Misión</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed text-justify">
          Empresa que ofrece servicios de consultoría, docencia investigación a
          nivel empresarial, y productos de Tecnología de Información y
          Comunicaciones de calidad, en forma ética y transparente, con el mejor
          capital humano y los recursos tecnológicos, que permiten a nuestros
          clientes lograr sus objetivos.
        </p>
      </div>
      <!-- Visión -->
      <div class="bg-primary p-8 rounded-xl flex flex-col gap-4 text-white">
        <div
          class="w-12 h-12 rounded-lg bg-white/20 flex items-center justify-center"
        >
          <span class="text-white"><i class="fa-solid fa-eye"></i></span>
        </div>
        <h3 class="font-headline text-xl font-bold">Visión</h3>
        <p class="text-primary-fixed-dim text-sm leading-relaxed text-justify">
          Ser una de las mejores empresas en consultoría, docencia investigación
          a nivel empresarial, en Tecnología de Información y Comunicaciones, en
          el ámbito nacional e internacional, a través de la calidad e impacto
          de sus resultados.
        </p>
      </div>
    </div>
    <!-- Valores -->
     <div class="md:max-w-[45%]">
         <ValuesColumn />
     </div>
    
  </section>
  <!-- Team Section -->
  <section class="py-20 bg-surface-container-low overflow-hidden">
    <div class="px-6 mb-10 text-center">
      <h2 class="font-headline text-primary text-3xl font-extrabold">
        Liderazgo
      </h2>
      <p class="text-on-surface-variant mt-2">
        Expertos comprometidos con la excelencia institucional.
      </p>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-10">
      <Persona
        name="Carlos Alberto Rodriguez Patiño"
        rol="Co-fundador"
        rolDescription="Estratega en la transformación digital de organizaciones, especializado en la implementación de sistemas de información clínica
         de alta complejidad. Su enfoque combina la coordinación de talento distribuido con herramientas colaborativas de vanguardia para garantizar la precisión
          y eficacia en cada proyecto tecnológico."
        linkedinUrl="https://www.linkedin.com/in/carlos-aberto-rodriguez-2320a936/?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=ios_app"
        imgPath="/img/persona1.jpg"
      />
      <Persona
        name="Hazel Nynoschka Ramos Thomas"
        rol="Co-fundadora"
        rolDescription="Experta en el diseño y supervisión de estándares de calidad hospitalaria. 
        Su gestión se centra en la optimización de procesos críticos y la seguridad del paciente, 
        asegurando que la consultoría estratégica de CYTEC2R traduzca la innovación técnica en resultados
        seguros, humanos y de alto impacto para las instituciones de salud."
        linkedinUrl="https://www.linkedin.com/in/hazel-ramos-healthcare-quality/"
        imgPath="/img/persona2.jpg"
      />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 px-6 text-center">
    <div
      class="bg-white p-10 rounded-2xl shadow-xl shadow-on-surface/5 flex flex-col items-center gap-6 border border-outline-variant/10"
    >
      <h2 class="font-headline text-2xl font-bold text-primary">
        ¿Listo para transformar su institución?
      </h2>
      <p class="text-on-surface-variant">
        Conozca cómo nuestra metodología de precisión puede elevar sus
        estándares.
      </p>
      <a
        href="/contacto/"
        class="bg-primary hover:scale-105 transition-transform px-8 py-4 rounded-xl text-white font-bold flex items-center gap-2"
      >
        Contactar Consultor
        <span class="text-sm"><i class="fa-solid fa-arrow-right-long"></i></span
        >
      </a>
    </div>
  </section>
</BaseLayout>
