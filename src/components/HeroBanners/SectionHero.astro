---
const {title, subtitle, description, imgPath} = Astro.props;
---
<!-- Hero Section -->
<section class="relative min-h-[500px] flex items-center overflow-hidden bg-primary px-6">
    <div class="absolute inset-0 opacity-35">
        <img 
            alt="Clinical environment" 
            class="w-full h-full object-cover" 
            data-alt="clean bright hospital hallway with soft lighting and professional blue tones architectural perspective" 
            src={imgPath}
        />
    </div>
    <div class="absolute inset-0 bg-gradient-to-tr from-primary via-primary/90 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto w-full z-10">
        <span class="font-label text-xs tracking-[0.2em] text-secondary-fixed mb-4 block">{subtitle}</span>
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold text-on-primary tracking-tight max-w-3xl">
            {title}
        </h1>
        <p class="text-on-primary-container text-lg md:text-xl max-w-xl mt-6 leading-relaxed">
            {description}
        </p>
    </div>
</section>