---
const { name, rol, rolDescription, linkedinUrl, imgPath } = Astro.props;
---

<section
  class="w-[350px] snap-center bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm pb-5"
>
  {
    imgPath && (
      <img class="w-full h-84 object-cover object-top" data-alt="" src={imgPath} />
    )
  }
  <div class="p-6">
    <h4 class="text-center font-headline font-bold text-primary text-xl">{name}</h4>
    <span class="text-center text-secondary font-medium text-sm uppercase tracking-wider block mb-4">{rol}</span>
    <p class="text-justify text-on-surface-variant text-sm leading-relaxed">
        {rolDescription}
    </p>
  </div>

  <a
    class="my-0 mx-auto w-12 h-12 rounded-full bg-surface-container-highest flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all shadow-sm"
    href={linkedinUrl}
  >
    <span class="text-2xl"><i class="fa-brands fa-linkedin"></i></span>
  </a>
</section>
