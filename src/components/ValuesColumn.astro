---
import ListRowWithIcon from "./ListRowWithIcon.astro"
---

<div class="bg-surface-container-highest p-8 rounded-xl">
  <h3 class="font-headline text-xl font-bold text-primary mb-6">Valores</h3>
  <div class="space-y-7">
    <ListRowWithIcon
      title="Calidad"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Garantizamos resultados de alto impacto mediante el rigor metodológico en consultoría y docencia."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-award"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <!-- The border color match the background color to made it invisable -->

    <ListRowWithIcon
      title="Innovación"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Evolucionamos constantemente nuestras herramientas TIC para anticiparnos a los retos empresariales."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-lightbulb"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Transparencia"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Actuamos con total claridad en la gestión de recursos y comunicación de procesos con nuestros clientes."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-eye"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Ética"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Mantenemos una conducta íntegra y profesional como base de todos nuestros servicios y productos."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-scale-balanced"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Compromiso"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Nos involucramos plenamente con los objetivos de nuestros clientes para asegurar que logren sus metas."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-handshake"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Diligencia"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Ejecutamos proyectos con agilidad y precisión, optimizando el uso de recursos tecnológicos."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-bolt"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Organización"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Coordinamos talento distribuido bajo una estructura sólida que garantiza eficacia operativa."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-sitemap"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Seguridad"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Salvaguardamos la información y la integridad de los sistemas con los más altos estándares tecnológicos."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-shield-halved"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Responsabilidad"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Asumimos con seriedad el impacto de nuestras investigaciones y consultorías en el entorno empresarial."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-user-check"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Respeto al Ambiente"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Promovemos el uso eficiente de las TIC para reducir la huella ecológica de las instituciones."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-leaf"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Autenticidad"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Ofrecemos soluciones originales basadas en la experiencia única de nuestro capital humano especializado."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-fingerprint"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Integridad"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Somos congruentes entre lo que investigamos, enseñamos y ejecutamos en el ámbito profesional."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-gem"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
    <ListRowWithIcon
      title="Honestidad"
      titleSize="text-md"
      titleColor="text-black"
      titleWeight="font-bold"
      description="Construimos relaciones de confianza basadas en la verdad y el trato humano excepcional."
      descriptionColor="text-on-surface-variant"
      iconClass="fa-solid fa-hand-holding-heart"
      iconSize="text-2xl"
      iconColor="text-secondary"
      borderColor="border-surface-container-highest"
    />
  </div>
</div>
