---
const {title, subtitle} = Astro.props;
---

<section class="max-w-[1024px]">
    <div class="mb-6 lg:mb-15">
        <h1 class="text-5xl text-center text-PrussianBlue font-bold md:text-6xl lg:text-7xl">{title}</h1>
		<h2 class="text-xl text-center md:text-2xl">{subtitle}</h2>
    </div>
    <slot />
</section>