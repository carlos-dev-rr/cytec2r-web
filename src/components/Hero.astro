<section id="hero-container" class="bg-PrussianBlue relative text-left overflow-hidden flex-grow">
    <div class="text-white absolute z-20 w-1/2 p-3 flex flex-col h-full justify-between">
        <header>
            <h1 class="text-3xl">Eleva tu excelencia operativa</h1>
            <p class="text-sm text-justify mt-5 w-6/7">
